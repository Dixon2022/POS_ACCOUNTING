<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="" onclick="if(window.closeSidebar) window.closeSidebar();">
            <i class="bi bi-scissors me-2"></i>
            <span>COMPANY - Cuentas</span>
        </a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column p-2">
        <!-- Dashboard -->
        <div class="nav-item">
            <NavLink class="nav-link text-white d-flex align-items-center" href="" Match="NavLinkMatch.All" onclick="if(window.closeSidebar) window.closeSidebar();">
                <i class="bi bi-speedometer2 nav-icon"></i>
                <span>Dashboard</span>
            </NavLink>
        </div>

        <!-- Separador -->
        <hr class="my-2 border-secondary opacity-50" />

        <!-- Sección: Ventas -->
        <div class="nav-section">
            <button class="nav-section-header text-uppercase text-white w-100 d-flex align-items-center justify-content-between" 
                    @onclick="() => ventasExpanded = !ventasExpanded" type="button">
                <span class="d-flex align-items-center">
                    <i class="bi bi-cart me-2"></i>Ventas
                </span>
                <i class="bi @(ventasExpanded ? "bi-chevron-up" : "bi-chevron-down") transition-icon"></i>
            </button>
            
            <div class="nav-section-content @(ventasExpanded ? "expanded" : "collapsed")">
                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="ventas" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-cart-check nav-icon"></i>
                        <span>Nueva Venta</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="historial-ventas" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-receipt nav-icon"></i>
                        <span>Historial Ventas</span>
                    </NavLink>
                </div>
            </div>
        </div>

        <!-- Separador -->
        <hr class="my-2 border-secondary opacity-50" />

        <!-- Sección: Catálogo -->
        <div class="nav-section">
            <button class="nav-section-header text-uppercase text-white w-100 d-flex align-items-center justify-content-between" 
                    @onclick="() => catalogoExpanded = !catalogoExpanded" type="button">
                <span class="d-flex align-items-center">
                    <i class="bi bi-grid me-2"></i>Catálogo
                </span>
                <i class="bi @(catalogoExpanded ? "bi-chevron-up" : "bi-chevron-down") transition-icon"></i>
            </button>
            
            <div class="nav-section-content @(catalogoExpanded ? "expanded" : "collapsed")">
                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="servicios" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-brush nav-icon"></i>
                        <span>Servicios</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="productos" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-box-seam nav-icon"></i>
                        <span>Productos</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="variantes" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-palette nav-icon"></i>
                        <span>Variantes</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="inventario" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-box2 nav-icon"></i>
                        <span>Inventario</span>
                    </NavLink>
                </div>
            </div>
        </div>

        <!-- Separador -->
        <hr class="my-2 border-secondary opacity-50" />

        <!-- Sección: Compras -->
        <div class="nav-section">
            <button class="nav-section-header text-uppercase text-white w-100 d-flex align-items-center justify-content-between" 
                    @onclick="() => comprasExpanded = !comprasExpanded" type="button">
                <span class="d-flex align-items-center">
                    <i class="bi bi-bag me-2"></i>Compras
                </span>
                <i class="bi @(comprasExpanded ? "bi-chevron-up" : "bi-chevron-down") transition-icon"></i>
            </button>
            
            <div class="nav-section-content @(comprasExpanded ? "expanded" : "collapsed")">
                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="compras" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-bag-plus nav-icon"></i>
                        <span>Nueva Compra</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="historial-compras" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-bag nav-icon"></i>
                        <span>Historial Compras</span>
                    </NavLink>
                </div>
            </div>
        </div>

        <!-- Separador -->
        <hr class="my-2 border-secondary opacity-50" />

        <!-- Sección: Contactos -->
        <div class="nav-section">
            <button class="nav-section-header text-uppercase text-white w-100 d-flex align-items-center justify-content-between" 
                    @onclick="() => contactosExpanded = !contactosExpanded" type="button">
                <span class="d-flex align-items-center">
                    <i class="bi bi-person-lines-fill me-2"></i>Contactos
                </span>
                <i class="bi @(contactosExpanded ? "bi-chevron-up" : "bi-chevron-down") transition-icon"></i>
            </button>
            
            <div class="nav-section-content @(contactosExpanded ? "expanded" : "collapsed")">
                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="clientes" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-people nav-icon"></i>
                        <span>Clientes</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="proveedores" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-truck nav-icon"></i>
                        <span>Proveedores</span>
                    </NavLink>
                </div>
            </div>
        </div>

        <!-- Separador -->
        <hr class="my-2 border-secondary opacity-50" />

        <!-- Sección: Finanzas -->
        <div class="nav-section">
            <button class="nav-section-header text-uppercase text-white w-100 d-flex align-items-center justify-content-between" 
                    @onclick="() => finanzasExpanded = !finanzasExpanded" type="button">
                <span class="d-flex align-items-center">
                    <i class="bi bi-currency-dollar me-2"></i>Finanzas
                </span>
                <i class="bi @(finanzasExpanded ? "bi-chevron-up" : "bi-chevron-down") transition-icon"></i>
            </button>
            
            <div class="nav-section-content @(finanzasExpanded ? "expanded" : "collapsed")">
                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="historial-general" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-journal-text nav-icon"></i>
                        <span>Historial General</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="ingresos" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-cash-stack nav-icon"></i>
                        <span>Otros Ingresos</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link text-white d-flex align-items-center" href="gastos" onclick="if(window.closeSidebar) window.closeSidebar();">
                        <i class="bi bi-wallet2 nav-icon"></i>
                        <span>Gastos</span>
                    </NavLink>
                </div>
            </div>
        </div>

        <!-- Separador -->
        <hr class="my-2 border-secondary opacity-50" />
    </nav>
</div>

@code {
    private bool ventasExpanded = false;
    private bool catalogoExpanded = false;
    private bool comprasExpanded = false;
    private bool contactosExpanded = false;
    private bool finanzasExpanded = false;
}







