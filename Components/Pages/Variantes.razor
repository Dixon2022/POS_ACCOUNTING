@page "/variantes"
@inject IProductVariantService VariantService
@inject IProductService ProductService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Variantes de Productos - SilSalon</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-palette me-2"></i>Variantes de Productos
        </h2>
        <button class="btn btn-primary btn-lg" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg me-2"></i>Nueva Variante
        </button>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control form-control-lg" 
                               placeholder="Buscar variante..." 
                               @bind="searchTerm" 
                               @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <select class="form-select form-select-lg" @bind="selectedProductId">
                        <option value="0">Todos los productos</option>
                        @foreach (var product in products)
                        {
                            <option value="@product.Id">@product.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <div class="btn-group w-100" role="group">
                        <button type="button" class="btn @(showActiveOnly ? "btn-primary" : "btn-outline-primary") btn-lg"
                                @onclick="() => showActiveOnly = true">
                            Activos
                        </button>
                        <button type="button" class="btn @(!showActiveOnly ? "btn-primary" : "btn-outline-primary") btn-lg"
                                @onclick="() => showActiveOnly = false">
                            Todos
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover bg-white shadow-sm rounded">
                <thead class="table-light">
                    <tr>
                        <th class="py-3">Producto</th>
                        <th class="py-3">Variante</th>
                        <th class="py-3">Código</th>
                        <th class="py-3 text-end">Costo</th>
                        <th class="py-3 text-end">Precio Venta</th>
                        <th class="py-3 text-center">Stock</th>
                        <th class="py-3 text-center">Estado</th>
                        <th class="py-3 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var variant in FilteredVariants)
                    {
                        <tr class="@(!variant.IsActive ? "opacity-50" : "") @(variant.Stock <= 5 && variant.Stock > 0 ? "table-warning" : "") @(variant.Stock == 0 ? "table-danger" : "")">
                            <td class="py-3">@variant.ProductName</td>
                            <td class="py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-info bg-opacity-10 rounded-circle p-2 me-2">
                                        <i class="bi bi-palette text-info"></i>
                                    </div>
                                    <strong>@variant.Name</strong>
                                </div>
                            </td>
                            <td class="py-3">
                                <code>@(string.IsNullOrEmpty(variant.Code) ? "-" : variant.Code)</code>
                            </td>
                            <td class="py-3 text-end">@variant.CostPrice.ToString("C2")</td>
                            <td class="py-3 text-end text-primary fw-bold">@variant.SalePrice.ToString("C2")</td>
                            <td class="py-3 text-center">
                                @if (variant.Stock == 0)
                                {
                                    <span class="badge bg-danger">Agotado</span>
                                }
                                else if (variant.Stock <= 5)
                                {
                                    <span class="badge bg-warning text-dark">@variant.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@variant.Stock</span>
                                }
                            </td>
                            <td class="py-3 text-center">
                                @if (variant.IsActive)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="py-3 text-center">
                                <div class="btn-group">
                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowEditModal(variant)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn @(variant.IsActive ? "btn-outline-warning" : "btn-outline-success") btn-sm" 
                                            @onclick="() => ToggleActive(variant.Id)">
                                        <i class="bi @(variant.IsActive ? "bi-pause" : "bi-play")"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowDeleteConfirm(variant)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!FilteredVariants.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-palette text-muted" style="font-size: 4rem;"></i>
                <h4 class="text-muted mt-3">No hay variantes</h4>
                <p class="text-muted">Agrega tu primera variante haciendo clic en el botón "Nueva Variante"</p>
            </div>
        }
    }
</div>

<!-- Modal Crear/Editar -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-palette me-2"></i>
                        @(isEditing ? "Editar Variante" : "Nueva Variante")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="currentVariant" OnValidSubmit="SaveVariant">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Producto *</label>
                                <InputSelect class="form-select form-select-lg" @bind-Value="currentVariant.ProductId">
                                    <option value="0">Seleccione un producto</option>
                                    @foreach (var product in products)
                                    {
                                        <option value="@product.Id">@product.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Nombre de la Variante *</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentVariant.Name" 
                                           placeholder="Ej: Rubio 7.0" />
                                <ValidationMessage For="() => currentVariant.Name" class="text-danger" />
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Código</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentVariant.Code" 
                                           placeholder="Ej: RUB-70" />
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Precio de Costo</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <InputNumber class="form-control form-control-lg" @bind-Value="currentVariant.CostPrice" />
                                </div>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Precio de Venta</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <InputNumber class="form-control form-control-lg" @bind-Value="currentVariant.SalePrice" />
                                </div>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Stock Inicial</label>
                                <InputNumber class="form-control form-control-lg" @bind-Value="currentVariant.Stock" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-lg" @onclick="CloseModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-lg" disabled="@(currentVariant.ProductId == 0)">
                            <i class="bi bi-check-lg me-2"></i>Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-palette text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">¿Eliminar "@variantToDelete?.FullName"?</h4>
                    <p class="text-muted">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeleteVariant">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public int? ProductId { get; set; }

    private List<ProductVariantDto> variants = new();
    private List<ProductDto> products = new();
    private ProductVariantDto currentVariant = new();
    private ProductVariantDto? variantToDelete;
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private bool isEditing = false;
    private string searchTerm = "";
    private int selectedProductId = 0;
    private bool showActiveOnly = true;

    private IEnumerable<ProductVariantDto> FilteredVariants => variants
        .Where(v => !showActiveOnly || v.IsActive)
        .Where(v => selectedProductId == 0 || v.ProductId == selectedProductId)
        .Where(v => string.IsNullOrEmpty(searchTerm) || 
                    v.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (v.Code?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (v.ProductName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        if (ProductId.HasValue)
        {
            selectedProductId = ProductId.Value;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        variants = (await VariantService.GetAllAsync()).ToList();
        products = (await ProductService.GetActiveAsync()).ToList();
        isLoading = false;
    }

    private void ShowCreateModal()
    {
        currentVariant = new ProductVariantDto
        {
            ProductId = selectedProductId
        };
        isEditing = false;
        showModal = true;
    }

    private void ShowEditModal(ProductVariantDto variant)
    {
        currentVariant = new ProductVariantDto
        {
            Id = variant.Id,
            ProductId = variant.ProductId,
            Name = variant.Name,
            Code = variant.Code,
            CostPrice = variant.CostPrice,
            SalePrice = variant.SalePrice,
            Stock = variant.Stock,
            IsActive = variant.IsActive
        };
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentVariant = new();
    }

    private async Task SaveVariant()
    {
        if (isEditing)
        {
            await VariantService.UpdateAsync(currentVariant);
        }
        else
        {
            await VariantService.CreateAsync(currentVariant);
        }

        await LoadData();
        CloseModal();
    }

    private void ShowDeleteConfirm(ProductVariantDto variant)
    {
        variantToDelete = variant;
        showDeleteModal = true;
    }

    private async Task DeleteVariant()
    {
        if (variantToDelete != null)
        {
            await VariantService.DeleteAsync(variantToDelete.Id);
            await LoadData();
        }
        showDeleteModal = false;
        variantToDelete = null;
    }

    private async Task ToggleActive(int id)
    {
        await VariantService.ToggleActiveAsync(id);
        await LoadData();
    }
}
