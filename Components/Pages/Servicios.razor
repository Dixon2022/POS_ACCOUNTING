@page "/servicios"
@inject IServiceService ServiceService
@rendermode InteractiveServer

<PageTitle>Servicios - Company</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-brush me-2"></i>Servicios
        </h2>
        <button class="btn btn-primary btn-lg" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg me-2"></i>Nuevo Servicio
        </button>
    </div>

    <!-- Barra de búsqueda -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control form-control-lg" 
                               placeholder="Buscar servicio..." 
                               @bind="searchTerm" 
                               @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <div class="btn-group w-100" role="group">
                        <button type="button" class="btn @(showActiveOnly ? "btn-primary" : "btn-outline-primary") btn-lg"
                                @onclick="() => showActiveOnly = true">
                            Activos
                        </button>
                        <button type="button" class="btn @(!showActiveOnly ? "btn-primary" : "btn-outline-primary") btn-lg"
                                @onclick="() => showActiveOnly = false">
                            Todos
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var service in FilteredServices)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card border-0 shadow-sm h-100 @(!service.IsActive ? "opacity-50" : "")">
                        <div class="card-body text-center">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-4 mx-auto mb-3" style="width: fit-content;">
                                <i class="bi bi-scissors text-primary fs-2"></i>
                            </div>
                            <h5 class="mb-2">@service.Name</h5>
                            <h4 class="text-primary mb-3">@service.BasePrice.ToString("C2")</h4>
                            @if (!service.IsActive)
                            {
                                <span class="badge bg-secondary mb-2">Inactivo</span>
                            }
                            <div class="d-flex justify-content-center gap-2 mt-3">
                                <button class="btn btn-outline-primary" @onclick="() => ShowEditModal(service)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn @(service.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                        @onclick="() => ToggleActive(service.Id)">
                                    <i class="bi @(service.IsActive ? "bi-pause" : "bi-play")"></i>
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirm(service)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!FilteredServices.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-brush text-muted" style="font-size: 4rem;"></i>
                <h4 class="text-muted mt-3">No hay servicios</h4>
                <p class="text-muted">Agrega tu primer servicio haciendo clic en el botón "Nuevo Servicio"</p>
            </div>
        }
    }
</div>

<!-- Modal Crear/Editar -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-brush me-2"></i>
                        @(isEditing ? "Editar Servicio" : "Nuevo Servicio")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="currentService" OnValidSubmit="SaveService">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Servicio *</label>
                            <InputText class="form-control form-control-lg" @bind-Value="currentService.Name" 
                                       placeholder="Ej: Corte de cabello" />
                            <ValidationMessage For="() => currentService.Name" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Precio Base</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control form-control-lg" @bind-Value="currentService.BasePrice" 
                                             placeholder="0.00" />
                            </div>
                            <small class="text-muted">El precio puede modificarse al momento de la venta</small>
                            <ValidationMessage For="() => currentService.BasePrice" class="text-danger" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-lg" @onclick="CloseModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-lg me-2"></i>Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-brush text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">żEliminar "@serviceToDelete?.Name"?</h4>
                    <p class="text-muted">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeleteService">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ServiceDto> services = new();
    private ServiceDto currentService = new();
    private ServiceDto? serviceToDelete;
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private bool isEditing = false;
    private string searchTerm = "";
    private bool showActiveOnly = true;

    private IEnumerable<ServiceDto> FilteredServices => services
        .Where(s => !showActiveOnly || s.IsActive)
        .Where(s => string.IsNullOrEmpty(searchTerm) || 
                    s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadServices();
    }

    private async Task LoadServices()
    {
        isLoading = true;
        services = (await ServiceService.GetAllAsync()).ToList();
        isLoading = false;
    }

    private void ShowCreateModal()
    {
        currentService = new ServiceDto();
        isEditing = false;
        showModal = true;
    }

    private void ShowEditModal(ServiceDto service)
    {
        currentService = new ServiceDto
        {
            Id = service.Id,
            Name = service.Name,
            BasePrice = service.BasePrice,
            IsActive = service.IsActive
        };
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentService = new();
    }

    private async Task SaveService()
    {
        if (isEditing)
        {
            await ServiceService.UpdateAsync(currentService);
        }
        else
        {
            await ServiceService.CreateAsync(currentService);
        }

        await LoadServices();
        CloseModal();
    }

    private void ShowDeleteConfirm(ServiceDto service)
    {
        serviceToDelete = service;
        showDeleteModal = true;
    }

    private async Task DeleteService()
    {
        if (serviceToDelete != null)
        {
            await ServiceService.DeleteAsync(serviceToDelete.Id);
            await LoadServices();
        }
        showDeleteModal = false;
        serviceToDelete = null;
    }

    private async Task ToggleActive(int id)
    {
        await ServiceService.ToggleActiveAsync(id);
        await LoadServices();
    }
}
