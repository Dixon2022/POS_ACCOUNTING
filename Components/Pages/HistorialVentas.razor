@page "/historial-ventas"
@inject ISaleService SaleService
@inject ICustomerService CustomerService
@rendermode InteractiveServer

<PageTitle>Historial de Ventas - SilSalon</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-receipt me-2"></i>Historial de Ventas
        </h2>
        <a href="/ventas" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-lg me-2"></i>Nueva Venta
        </a>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="startDate" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="endDate" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Cliente</label>
                    <select class="form-select form-select-lg" @bind="selectedCustomerId">
                        <option value="">Todos los clientes</option>
                        @foreach (var customer in customers)
                        {
                            <option value="@customer.Id">@customer.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-primary btn-lg w-100" @onclick="FilterSales">
                        <i class="bi bi-search me-2"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Total Ventas</h6>
                    <h2 class="mb-0">@sales.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Ingresos</h6>
                    <h2 class="mb-0">@sales.Sum(s => s.Total).ToString("C2")</h2>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Promedio por Venta</h6>
                    <h2 class="mb-0">@(sales.Any() ? (sales.Sum(s => s.Total) / sales.Count).ToString("C2") : "$0.00")</h2>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!sales.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-receipt text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">No hay ventas registradas</h4>
            <p class="text-muted">Las ventas que realices aparecerán aquí</p>
            <a href="/ventas" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-plus-lg me-2"></i>Realizar Primera Venta
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var sale in sales)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-12 col-md-2">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                            <i class="bi bi-receipt text-primary fs-4"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted">Venta #@sale.Id</small>
                                            <h5 class="mb-0">@sale.Date.ToString("dd/MM/yyyy HH:mm")</h5>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-2">
                                    <small class="text-muted d-block">Cliente</small>
                                    <strong>@(sale.CustomerName ?? "Venta General")</strong>
                                </div>
                                <div class="col-12 col-md-2">
                                    <small class="text-muted d-block">Método de Pago</small>
                                    <span class="badge @GetPaymentMethodBadgeClass(sale.PaymentMethod)">
                                        @GetPaymentMethodName(sale.PaymentMethod)
                                    </span>
                                </div>
                                <div class="col-12 col-md-2">
                                    <small class="text-muted d-block">Items</small>
                                    <span class="badge bg-secondary">@sale.Items.Count</span>
                                </div>
                                <div class="col-12 col-md-2">
                                    <small class="text-muted d-block">Total</small>
                                    <h4 class="text-success mb-0">@sale.Total.ToString("C2")</h4>
                                </div>
                                <div class="col-12 col-md-2 text-end">
                                    <button class="btn btn-outline-primary me-2" @onclick="() => ToggleDetails(sale.Id)">
                                        <i class="bi @(expandedSaleId == sale.Id ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                    </button>
                                    <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirm(sale)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>

                            @if (expandedSaleId == sale.Id)
                            {
                                <hr class="my-3" />
                                @if (!string.IsNullOrEmpty(sale.Notes))
                                {
                                    <div class="alert alert-light mb-3">
                                        <i class="bi bi-sticky me-2"></i>
                                        <strong>Notas:</strong> @sale.Notes
                                    </div>
                                }
                                <h6 class="text-muted mb-3">Detalle de la venta:</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Tipo</th>
                                                <th>Item</th>
                                                <th class="text-center">Cantidad</th>
                                                <th class="text-end">Precio Unit.</th>
                                                <th class="text-end">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in sale.Items)
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="badge @(item.ItemType == ItemType.Service ? "bg-info" : "bg-warning")">
                                                            @(item.ItemType == ItemType.Service ? "Servicio" : "Producto")
                                                        </span>
                                                    </td>
                                                    <td>@item.ItemName</td>
                                                    <td class="text-center">@item.Quantity</td>
                                                    <td class="text-end">@item.UnitPrice.ToString("C2")</td>
                                                    <td class="text-end fw-bold">@item.Total.ToString("C2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-receipt-cutoff text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">żEliminar Venta #@saleToDelete?.Id?</h4>
                    <p class="text-muted">El stock de productos será restaurado. Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeleteSale">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SaleDto> sales = new();
    private List<CustomerDto> customers = new();
    private SaleDto? saleToDelete;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private int? expandedSaleId = null;
    private DateTime startDate = DateTime.Today.AddDays(-30);
    private DateTime endDate = DateTime.Today;
    private int? selectedCustomerId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        sales = (await SaleService.GetAllAsync()).ToList();
        customers = (await CustomerService.GetAllAsync()).ToList();
        isLoading = false;
    }

    private async Task FilterSales()
    {
        isLoading = true;
        sales = (await SaleService.GetByDateRangeAndCustomerAsync(startDate, endDate, selectedCustomerId)).ToList();
        isLoading = false;
    }

    private void ToggleDetails(int saleId)
    {
        expandedSaleId = expandedSaleId == saleId ? null : saleId;
    }

    private void ShowDeleteConfirm(SaleDto sale)
    {
        saleToDelete = sale;
        showDeleteModal = true;
    }

    private async Task DeleteSale()
    {
        if (saleToDelete != null)
        {
            await SaleService.DeleteAsync(saleToDelete.Id);
            await LoadData();
        }
        showDeleteModal = false;
        saleToDelete = null;
    }

    private string GetPaymentMethodName(PaymentMethod method) => method switch
    {
        PaymentMethod.Efectivo => "Efectivo",
        PaymentMethod.SINPE => "SINPE",
        PaymentMethod.Tarjeta => "Tarjeta",
        _ => "Desconocido"
    };

    private string GetPaymentMethodBadgeClass(PaymentMethod method) => method switch
    {
        PaymentMethod.Efectivo => "bg-success",
        PaymentMethod.SINPE => "bg-primary",
        PaymentMethod.Tarjeta => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
