@page "/proveedores"
@inject ISupplierService SupplierService
@rendermode InteractiveServer

<PageTitle>Proveedores - SilSalon</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-truck me-2"></i>Proveedores
        </h2>
        <button class="btn btn-primary btn-lg" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg me-2"></i>Nuevo Proveedor
        </button>
    </div>

    <!-- Barra de búsqueda -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control form-control-lg" 
                               placeholder="Buscar proveedor..." 
                               @bind="searchTerm" 
                               @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <div class="btn-group w-100" role="group">
                        <button type="button" class="btn @(showActiveOnly ? "btn-primary" : "btn-outline-primary") btn-lg"
                                @onclick="() => showActiveOnly = true">
                            Activos
                        </button>
                        <button type="button" class="btn @(!showActiveOnly ? "btn-primary" : "btn-outline-primary") btn-lg"
                                @onclick="() => showActiveOnly = false">
                            Todos
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var supplier in FilteredSuppliers)
            {
                <div class="col-12 col-lg-6">
                    <div class="card border-0 shadow-sm h-100 @(!supplier.IsActive ? "opacity-50" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-truck text-success fs-4"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1">@supplier.Name</h5>
                                        @if (!string.IsNullOrEmpty(supplier.ContactPerson))
                                        {
                                            <p class="text-muted mb-0 small">
                                                <i class="bi bi-person me-1"></i>@supplier.ContactPerson
                                            </p>
                                        }
                                    </div>
                                </div>
                                @if (!supplier.IsActive)
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </div>
                            <hr />
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-telephone me-1"></i>Teléfono
                                    </small>
                                    <span>@(string.IsNullOrEmpty(supplier.Phone) ? "No registrado" : supplier.Phone)</span>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-envelope me-1"></i>Email
                                    </small>
                                    <span class="text-truncate d-block">@(string.IsNullOrEmpty(supplier.Email) ? "No registrado" : supplier.Email)</span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>
                                    Desde: @supplier.CreatedDate.ToString("dd/MM/yyyy")
                                </small>
                                <div class="btn-group">
                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowEditModal(supplier)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn @(supplier.IsActive ? "btn-outline-warning" : "btn-outline-success") btn-sm" 
                                            @onclick="() => ToggleActive(supplier.Id)">
                                        <i class="bi @(supplier.IsActive ? "bi-pause" : "bi-play")"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowDeleteConfirm(supplier)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!FilteredSuppliers.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-truck text-muted" style="font-size: 4rem;"></i>
                <h4 class="text-muted mt-3">No hay proveedores</h4>
                <p class="text-muted">Agrega tu primer proveedor haciendo clic en el botón "Nuevo Proveedor"</p>
            </div>
        }
    }
</div>

<!-- Modal Crear/Editar -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-truck me-2"></i>
                        @(isEditing ? "Editar Proveedor" : "Nuevo Proveedor")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="currentSupplier" OnValidSubmit="SaveSupplier">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Nombre de la Empresa *</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentSupplier.Name" 
                                           placeholder="Nombre del proveedor" />
                                <ValidationMessage For="() => currentSupplier.Name" class="text-danger" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Persona de Contacto</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentSupplier.ContactPerson" 
                                           placeholder="Nombre del contacto" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Teléfono</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentSupplier.Phone" 
                                           placeholder="Número de teléfono" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Email</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentSupplier.Email" 
                                           placeholder="correo@ejemplo.com" />
                                <ValidationMessage For="() => currentSupplier.Email" class="text-danger" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-lg" @onclick="CloseModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-lg me-2"></i>Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-truck text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">¿Eliminar a @supplierToDelete?.Name?</h4>
                    <p class="text-muted">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeleteSupplier">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SupplierDto> suppliers = new();
    private SupplierDto currentSupplier = new();
    private SupplierDto? supplierToDelete;
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private bool isEditing = false;
    private string searchTerm = "";
    private bool showActiveOnly = true;

    private IEnumerable<SupplierDto> FilteredSuppliers => suppliers
        .Where(s => !showActiveOnly || s.IsActive)
        .Where(s => string.IsNullOrEmpty(searchTerm) || 
                    s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (s.ContactPerson?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        isLoading = true;
        suppliers = (await SupplierService.GetAllAsync()).ToList();
        isLoading = false;
    }

    private void ShowCreateModal()
    {
        currentSupplier = new SupplierDto();
        isEditing = false;
        showModal = true;
    }

    private void ShowEditModal(SupplierDto supplier)
    {
        currentSupplier = new SupplierDto
        {
            Id = supplier.Id,
            Name = supplier.Name,
            Phone = supplier.Phone,
            Email = supplier.Email,
            ContactPerson = supplier.ContactPerson,
            CreatedDate = supplier.CreatedDate,
            IsActive = supplier.IsActive
        };
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentSupplier = new();
    }

    private async Task SaveSupplier()
    {
        if (isEditing)
        {
            await SupplierService.UpdateAsync(currentSupplier);
        }
        else
        {
            await SupplierService.CreateAsync(currentSupplier);
        }

        await LoadSuppliers();
        CloseModal();
    }

    private void ShowDeleteConfirm(SupplierDto supplier)
    {
        supplierToDelete = supplier;
        showDeleteModal = true;
    }

    private async Task DeleteSupplier()
    {
        if (supplierToDelete != null)
        {
            await SupplierService.DeleteAsync(supplierToDelete.Id);
            await LoadSuppliers();
        }
        showDeleteModal = false;
        supplierToDelete = null;
    }

    private async Task ToggleActive(int id)
    {
        await SupplierService.ToggleActiveAsync(id);
        await LoadSuppliers();
    }
}
