@page "/"
@inject IDashboardService DashboardService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Dashboard - Company</PageTitle>

<div class="container-fluid">
    <h2 class="mb-4">
        <i class="bi bi-speedometer2 me-2"></i>Dashboard
    </h2>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (dashboard != null)
    {
        <!-- Tarjetas de métricas principales -->
        <div class="row g-4 mb-4">
            <!-- Ingresos Hoy -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1 small">Ingresos Hoy</p>
                                <h3 class="mb-0 text-success">@dashboard.IncomeToday.ToString("C2")</h3>
                            </div>
                            <div class="bg-success bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-cash-coin text-success fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ingresos del Mes -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1 small">Ingresos del Mes</p>
                                <h3 class="mb-0 text-primary">@dashboard.IncomeMonth.ToString("C2")</h3>
                            </div>
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-graph-up-arrow text-primary fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Gastos del Mes -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1 small">Gastos del Mes</p>
                                <h3 class="mb-0 text-danger">@dashboard.ExpensesMonth.ToString("C2")</h3>
                            </div>
                            <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-wallet2 text-danger fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ganancia Neta -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1 small">Ganancia Neta</p>
                                <h3 class="mb-0 @(dashboard.NetProfit >= 0 ? "text-success" : "text-danger")">
                                    @dashboard.NetProfit.ToString("C2")
                                </h3>
                            </div>
                            <div class="@(dashboard.NetProfit >= 0 ? "bg-success" : "bg-danger") bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-trophy @(dashboard.NetProfit >= 0 ? "text-success" : "text-danger") fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Segunda fila de métricas -->
        <div class="row g-4 mb-4">
            <!-- Compras del Mes -->
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="bg-warning bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-bag text-warning fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0 small">Compras del Mes</p>
                                <h4 class="mb-0">@dashboard.PurchasesMonth.ToString("C2")</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Clientes Nuevos -->
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-person-plus text-info fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0 small">Clientes Nuevos</p>
                                <h4 class="mb-0">@dashboard.NewCustomersMonth</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Clientes Atendidos -->
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="bg-secondary bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-people text-secondary fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0 small">Clientes Atendidos</p>
                                <h4 class="mb-0">@dashboard.CustomersServedMonth</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráficos y Estadísticas -->
        <div class="row g-4 mb-4">
            <!-- Gráfico de ventas -->
            <div class="col-12 col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0">
                        <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Ventas Últimos 7 Días</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="salesChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>

            <!-- Resumen -->
            <div class="col-12 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0">
                        <h5 class="mb-0"><i class="bi bi-star me-2"></i>Destacados del Mes</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <p class="text-muted mb-1 small">
                                <i class="bi bi-box me-1"></i>Producto Más Vendido
                            </p>
                            <h6 class="mb-0">@(dashboard.BestSellingProduct ?? "Sin datos")</h6>
                        </div>
                        <div class="mb-4">
                            <p class="text-muted mb-1 small">
                                <i class="bi bi-scissors me-1"></i>Servicio Más Solicitado
                            </p>
                            <h6 class="mb-0">@(dashboard.MostRequestedService ?? "Sin datos")</h6>
                        </div>
                        <div class="mb-4">
                            <p class="text-muted mb-1 small">
                                <i class="bi bi-truck me-1"></i>Proveedor Principal
                            </p>
                            <h6 class="mb-0">@(dashboard.MainSupplier ?? "Sin datos")</h6>
                        </div>
                        <div>
                            <p class="text-muted mb-1 small">
                                <i class="bi bi-box2 me-1"></i>Valor del Inventario
                            </p>
                            <h6 class="mb-0 text-primary">@dashboard.TotalInventoryValue.ToString("C2")</h6>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráfico de distribución -->
        <div class="row g-4">
            <div class="col-12 col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0">
                        <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Distribución Financiera</h5>
                    </div>
                    <div class="card-body d-flex justify-content-center">
                        <canvas id="distributionChart" style="max-height: 250px; max-width: 250px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0">
                        <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Acciones Rápidas</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6">
                                <a href="ventas" class="btn btn-primary btn-lg w-100 py-3">
                                    <i class="bi bi-cart-plus d-block fs-2 mb-1"></i>
                                    Nueva Venta
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="compras" class="btn btn-success btn-lg w-100 py-3">
                                    <i class="bi bi-bag-plus d-block fs-2 mb-1"></i>
                                    Nueva Compra
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="clientes" class="btn btn-info btn-lg w-100 py-3 text-white">
                                    <i class="bi bi-person-plus d-block fs-2 mb-1"></i>
                                    Nuevo Cliente
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="gastos" class="btn btn-warning btn-lg w-100 py-3">
                                    <i class="bi bi-wallet2 d-block fs-2 mb-1"></i>
                                    Registrar Gasto
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardDto? dashboard;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && dashboard != null)
        {
            await RenderCharts();
        }
    }

    private async Task LoadDashboard()
    {
        isLoading = true;
        dashboard = await DashboardService.GetDashboardDataAsync();
        isLoading = false;
    }

    private async Task RenderCharts()
    {
        if (dashboard == null) return;

        var salesLabels = dashboard.SalesLast7Days.Select(x => x.Label).ToArray();
        var salesData = dashboard.SalesLast7Days.Select(x => (double)x.Value).ToArray();

        await JS.InvokeVoidAsync("eval", $@"
            const salesCtx = document.getElementById('salesChart');
            if (salesCtx) {{
                new Chart(salesCtx, {{
                    type: 'bar',
                    data: {{
                        labels: {System.Text.Json.JsonSerializer.Serialize(salesLabels)},
                        datasets: [{{
                            label: 'Ventas ($)',
                            data: {System.Text.Json.JsonSerializer.Serialize(salesData)},
                            backgroundColor: 'rgba(13, 110, 253, 0.7)',
                            borderColor: 'rgba(13, 110, 253, 1)',
                            borderWidth: 1,
                            borderRadius: 5
                        }}]
                    }},
                    options: {{
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {{
                            legend: {{ display: false }}
                        }},
                        scales: {{
                            y: {{ beginAtZero: true }}
                        }}
                    }}
                }});
            }}
        ");

        var distLabels = dashboard.ExpensesVsIncomeMonth.Select(x => x.Label).ToArray();
        var distData = dashboard.ExpensesVsIncomeMonth.Select(x => (double)x.Value).ToArray();

        await JS.InvokeVoidAsync("eval", $@"
            const distCtx = document.getElementById('distributionChart');
            if (distCtx) {{
                new Chart(distCtx, {{
                    type: 'doughnut',
                    data: {{
                        labels: {System.Text.Json.JsonSerializer.Serialize(distLabels)},
                        datasets: [{{
                            data: {System.Text.Json.JsonSerializer.Serialize(distData)},
                            backgroundColor: [
                                'rgba(25, 135, 84, 0.8)',
                                'rgba(220, 53, 69, 0.8)',
                                'rgba(255, 193, 7, 0.8)'
                            ],
                            borderWidth: 0
                        }}]
                    }},
                    options: {{
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {{
                            legend: {{
                                position: 'bottom'
                            }}
                        }}
                    }}
                }});
            }}
        ");
    }
}
