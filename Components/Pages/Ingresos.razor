@page "/ingresos"
@inject IIncomeService IncomeService
@rendermode InteractiveServer

<PageTitle>Otros Ingresos - SilSalon</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-cash-stack me-2"></i>Otros Ingresos
        </h2>
        <button class="btn btn-success btn-lg" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg me-2"></i>Nuevo Ingreso
        </button>
    </div>

    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle me-2"></i>
        <strong>Nota:</strong> Aquí se registran ingresos adicionales que no provienen de ventas, como propinas, devoluciones, etc.
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="startDate" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="endDate" />
                </div>
                <div class="col-12 col-md-4">
                    <button class="btn btn-primary btn-lg w-100" @onclick="FilterIncomes">
                        <i class="bi bi-search me-2"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Total Ingresos (Período)</h6>
                    <h2 class="mb-0">@FilteredIncomes.Sum(i => i.Amount).ToString("C2")</h2>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Cantidad de Ingresos</h6>
                    <h2 class="mb-0">@FilteredIncomes.Count()</h2>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!FilteredIncomes.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cash-stack text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">No hay ingresos adicionales registrados</h4>
            <p class="text-muted">Los ingresos que no son ventas aparecerán aquí</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var income in FilteredIncomes)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h5 class="mb-1">@income.Description</h5>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar me-1"></i>
                                        @income.Date.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                                <h4 class="text-success mb-0">@income.Amount.ToString("C2")</h4>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowEditModal(income)">
                                    <i class="bi bi-pencil me-1"></i>Editar
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowDeleteConfirm(income)">
                                    <i class="bi bi-trash me-1"></i>Eliminar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-cash-stack me-2"></i>
                        @(isEditing ? "Editar Ingreso" : "Nuevo Ingreso")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="currentIncome" OnValidSubmit="SaveIncome">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Descripción *</label>
                            <InputText class="form-control form-control-lg" @bind-Value="currentIncome.Description" 
                                       placeholder="Ej: Propina, Devolución" />
                            <ValidationMessage For="() => currentIncome.Description" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Monto *</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control form-control-lg" @bind-Value="currentIncome.Amount" />
                            </div>
                            <ValidationMessage For="() => currentIncome.Amount" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fecha</label>
                            <InputDate class="form-control form-control-lg" @bind-Value="currentIncome.Date" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-lg" @onclick="CloseModal">Cancelar</button>
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-check-lg me-2"></i>Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-cash-stack text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">¿Eliminar este ingreso?</h4>
                    <p class="text-muted">@incomeToDelete?.Description</p>
                    <p class="text-success fw-bold">@incomeToDelete?.Amount.ToString("C2")</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeleteIncome">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<IncomeDto> incomes = new();
    private IncomeDto currentIncome = new();
    private IncomeDto? incomeToDelete;
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private bool isEditing = false;
    private DateTime startDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime endDate = DateTime.Today;

    private IEnumerable<IncomeDto> FilteredIncomes => incomes
        .Where(i => i.Date.Date >= startDate.Date && i.Date.Date <= endDate.Date)
        .OrderByDescending(i => i.Date);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        incomes = (await IncomeService.GetAllAsync()).ToList();
        isLoading = false;
    }

    private async Task FilterIncomes()
    {
        isLoading = true;
        incomes = (await IncomeService.GetByDateRangeAsync(startDate, endDate)).ToList();
        isLoading = false;
    }

    private void ShowCreateModal()
    {
        currentIncome = new IncomeDto { Date = DateTime.Now };
        isEditing = false;
        showModal = true;
    }

    private void ShowEditModal(IncomeDto income)
    {
        currentIncome = new IncomeDto
        {
            Id = income.Id,
            Description = income.Description,
            Amount = income.Amount,
            Date = income.Date
        };
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentIncome = new();
    }

    private async Task SaveIncome()
    {
        if (isEditing)
        {
            await IncomeService.UpdateAsync(currentIncome);
        }
        else
        {
            await IncomeService.CreateAsync(currentIncome);
        }

        await LoadData();
        CloseModal();
    }

    private void ShowDeleteConfirm(IncomeDto income)
    {
        incomeToDelete = income;
        showDeleteModal = true;
    }

    private async Task DeleteIncome()
    {
        if (incomeToDelete != null)
        {
            await IncomeService.DeleteAsync(incomeToDelete.Id);
            await LoadData();
        }
        showDeleteModal = false;
        incomeToDelete = null;
    }
}
