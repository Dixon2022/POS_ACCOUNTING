@page "/gastos"
@inject IExpenseService ExpenseService
@rendermode InteractiveServer

<PageTitle>Gastos - Company</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-wallet2 me-2"></i>Gastos
        </h2>
        <button class="btn btn-danger btn-lg" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg me-2"></i>Nuevo Gasto
        </button>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="startDate" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="endDate" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Categoría</label>
                    <select class="form-select form-select-lg" @bind="selectedCategory">
                        <option value="">Todas</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-primary btn-lg w-100" @onclick="FilterExpenses">
                        <i class="bi bi-search me-2"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Total Gastos (Período)</h6>
                    <h2 class="mb-0">@FilteredExpenses.Sum(e => e.Amount).ToString("C2")</h2>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm bg-secondary text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Cantidad de Gastos</h6>
                    <h2 class="mb-0">@FilteredExpenses.Count()</h2>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!FilteredExpenses.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-wallet2 text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">No hay gastos registrados</h4>
            <p class="text-muted">Los gastos que registres aparecerán aquí</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var expense in FilteredExpenses)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    @if (!string.IsNullOrEmpty(expense.Category))
                                    {
                                        <span class="badge bg-secondary mb-2">@expense.Category</span>
                                    }
                                    <span class="badge @GetPaymentMethodBadgeClass(expense.PaymentMethod) mb-2 ms-1">
                                        @GetPaymentMethodName(expense.PaymentMethod)
                                    </span>
                                    <h5 class="mb-1">@expense.Description</h5>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar me-1"></i>
                                        @expense.Date.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                                <h4 class="text-danger mb-0">@expense.Amount.ToString("C2")</h4>
                            </div>
                            @if (!string.IsNullOrEmpty(expense.Notes))
                            {
                                <div class="alert alert-light py-2 mb-2">
                                    <small><i class="bi bi-sticky me-1"></i>@expense.Notes</small>
                                </div>
                            }
                            <hr />
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowEditModal(expense)">
                                    <i class="bi bi-pencil me-1"></i>Editar
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowDeleteConfirm(expense)">
                                    <i class="bi bi-trash me-1"></i>Eliminar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-wallet2 me-2"></i>
                        @(isEditing ? "Editar Gasto" : "Nuevo Gasto")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="currentExpense" OnValidSubmit="SaveExpense">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Descripción *</label>
                            <InputText class="form-control form-control-lg" @bind-Value="currentExpense.Description" 
                                       placeholder="Ej: Pago de luz" />
                            <ValidationMessage For="() => currentExpense.Description" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Monto *</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control form-control-lg" @bind-Value="currentExpense.Amount" />
                            </div>
                            <ValidationMessage For="() => currentExpense.Amount" class="text-danger" />
                        </div>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Categoría</label>
                                <InputText class="form-control form-control-lg" @bind-Value="currentExpense.Category" 
                                           placeholder="Ej: Servicios, Renta, Nómina" list="categories-list" />
                                <datalist id="categories-list">
                                    @foreach (var category in categories)
                                    {
                                        <option value="@category" />
                                    }
                                </datalist>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Método de Pago</label>
                                <InputSelect class="form-select form-select-lg" @bind-Value="currentExpense.PaymentMethod">
                                    <option value="@PaymentMethod.Efectivo">Efectivo</option>
                                    <option value="@PaymentMethod.SINPE">SINPE</option>
                                    <option value="@PaymentMethod.Tarjeta">Tarjeta</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="mb-3 mt-3">
                            <label class="form-label">Fecha</label>
                            <InputDate class="form-control form-control-lg" @bind-Value="currentExpense.Date" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notas (opcional)</label>
                            <InputTextArea class="form-control" @bind-Value="currentExpense.Notes" 
                                           placeholder="Detalle adicional..." rows="2" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-lg" @onclick="CloseModal">Cancelar</button>
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-check-lg me-2"></i>Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-wallet2 text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">żEliminar este gasto?</h4>
                    <p class="text-muted">@expenseToDelete?.Description</p>
                    <p class="text-danger fw-bold">@expenseToDelete?.Amount.ToString("C2")</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeleteExpense">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ExpenseDto> expenses = new();
    private List<string> categories = new();
    private ExpenseDto currentExpense = new();
    private ExpenseDto? expenseToDelete;
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private bool isEditing = false;
    private DateTime startDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime endDate = DateTime.Today;
    private string selectedCategory = "";

    private IEnumerable<ExpenseDto> FilteredExpenses => expenses
        .Where(e => string.IsNullOrEmpty(selectedCategory) || e.Category == selectedCategory)
        .Where(e => e.Date.Date >= startDate.Date && e.Date.Date <= endDate.Date)
        .OrderByDescending(e => e.Date);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        expenses = (await ExpenseService.GetAllAsync()).ToList();
        categories = (await ExpenseService.GetCategoriesAsync()).ToList();
        isLoading = false;
    }

    private async Task FilterExpenses()
    {
        isLoading = true;
        expenses = (await ExpenseService.GetByDateRangeAsync(startDate, endDate)).ToList();
        isLoading = false;
    }

    private void ShowCreateModal()
    {
        currentExpense = new ExpenseDto { Date = DateTime.Now };
        isEditing = false;
        showModal = true;
    }

    private void ShowEditModal(ExpenseDto expense)
    {
        currentExpense = new ExpenseDto
        {
            Id = expense.Id,
            Description = expense.Description,
            Amount = expense.Amount,
            Date = expense.Date,
            Category = expense.Category,
            PaymentMethod = expense.PaymentMethod,
            Notes = expense.Notes
        };
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentExpense = new();
    }

    private async Task SaveExpense()
    {
        if (isEditing)
        {
            await ExpenseService.UpdateAsync(currentExpense);
        }
        else
        {
            await ExpenseService.CreateAsync(currentExpense);
        }

        await LoadData();
        CloseModal();
    }

    private void ShowDeleteConfirm(ExpenseDto expense)
    {
        expenseToDelete = expense;
        showDeleteModal = true;
    }

    private async Task DeleteExpense()
    {
        if (expenseToDelete != null)
        {
            await ExpenseService.DeleteAsync(expenseToDelete.Id);
            await LoadData();
        }
        showDeleteModal = false;
        expenseToDelete = null;
    }

    private string GetPaymentMethodName(PaymentMethod method) => method switch
    {
        PaymentMethod.Efectivo => "Efectivo",
        PaymentMethod.SINPE => "SINPE",
        PaymentMethod.Tarjeta => "Tarjeta",
        _ => "Desconocido"
    };

    private string GetPaymentMethodBadgeClass(PaymentMethod method) => method switch
    {
        PaymentMethod.Efectivo => "bg-success",
        PaymentMethod.SINPE => "bg-primary",
        PaymentMethod.Tarjeta => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
