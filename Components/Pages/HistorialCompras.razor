@page "/historial-compras"
@inject IPurchaseService PurchaseService
@rendermode InteractiveServer

<PageTitle>Historial de Compras - SilSalon</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-bag me-2"></i>Historial de Compras
        </h2>
        <a href="/compras" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg me-2"></i>Nueva Compra
        </a>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="startDate" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control form-control-lg" 
                           @bind="endDate" />
                </div>
                <div class="col-12 col-md-4">
                    <button class="btn btn-primary btn-lg w-100" @onclick="FilterPurchases">
                        <i class="bi bi-search me-2"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Total Compras</h6>
                    <h2 class="mb-0">@purchases.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm bg-warning">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Inversión Total</h6>
                    <h2 class="mb-0">@purchases.Sum(p => p.Total).ToString("C2")</h2>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="opacity-75 mb-1">Promedio por Compra</h6>
                    <h2 class="mb-0">@(purchases.Any() ? (purchases.Sum(p => p.Total) / purchases.Count).ToString("C2") : "$0.00")</h2>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!purchases.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">No hay compras registradas</h4>
            <p class="text-muted">Las compras que realices aparecerán aquí</p>
            <a href="/compras" class="btn btn-success btn-lg mt-3">
                <i class="bi bi-plus-lg me-2"></i>Realizar Primera Compra
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var purchase in purchases)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-12 col-md-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                                            <i class="bi bi-bag text-success fs-4"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted">Compra #@purchase.Id</small>
                                            <h5 class="mb-0">@purchase.Date.ToString("dd/MM/yyyy")</h5>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-3">
                                    <small class="text-muted d-block">Proveedor</small>
                                    <strong>@purchase.SupplierName</strong>
                                </div>
                                <div class="col-12 col-md-2">
                                    <small class="text-muted d-block">Items</small>
                                    <span class="badge bg-secondary">@purchase.Items.Count</span>
                                </div>
                                <div class="col-12 col-md-2">
                                    <small class="text-muted d-block">Total</small>
                                    <h4 class="text-warning mb-0">@purchase.Total.ToString("C2")</h4>
                                </div>
                                <div class="col-12 col-md-2 text-end">
                                    <button class="btn btn-outline-primary me-2" @onclick="() => ToggleDetails(purchase.Id)">
                                        <i class="bi @(expandedPurchaseId == purchase.Id ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                    </button>
                                    <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirm(purchase)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>

                            @if (expandedPurchaseId == purchase.Id)
                            {
                                <hr class="my-3" />
                                <h6 class="text-muted mb-3">Detalle de la compra:</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Producto</th>
                                                <th class="text-center">Cantidad</th>
                                                <th class="text-end">Costo Unit.</th>
                                                <th class="text-end">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in purchase.Items)
                                            {
                                                <tr>
                                                    <td>@item.ProductVariantName</td>
                                                    <td class="text-center">@item.Quantity</td>
                                                    <td class="text-end">@item.UnitCost.ToString("C2")</td>
                                                    <td class="text-end fw-bold">@item.Total.ToString("C2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Confirmar Eliminar -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-bag-x text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">żEliminar Compra #@purchaseToDelete?.Id?</h4>
                    <p class="text-muted">El stock de productos será reducido. Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-lg" @onclick="DeletePurchase">
                        <i class="bi bi-trash me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PurchaseDto> purchases = new();
    private PurchaseDto? purchaseToDelete;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private int? expandedPurchaseId = null;
    private DateTime startDate = DateTime.Today.AddDays(-30);
    private DateTime endDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadPurchases();
    }

    private async Task LoadPurchases()
    {
        isLoading = true;
        purchases = (await PurchaseService.GetAllAsync()).ToList();
        isLoading = false;
    }

    private async Task FilterPurchases()
    {
        isLoading = true;
        purchases = (await PurchaseService.GetByDateRangeAsync(startDate, endDate)).ToList();
        isLoading = false;
    }

    private void ToggleDetails(int purchaseId)
    {
        expandedPurchaseId = expandedPurchaseId == purchaseId ? null : purchaseId;
    }

    private void ShowDeleteConfirm(PurchaseDto purchase)
    {
        purchaseToDelete = purchase;
        showDeleteModal = true;
    }

    private async Task DeletePurchase()
    {
        if (purchaseToDelete != null)
        {
            await PurchaseService.DeleteAsync(purchaseToDelete.Id);
            await LoadPurchases();
        }
        showDeleteModal = false;
        purchaseToDelete = null;
    }
}
